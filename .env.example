# Discord bot credentials (required)
DISCORD_TOKEN=your-bot-token
CLIENT_ID=your-application-id

# Register commands instantly to a single guild (recommended).
# Leave blank to register global commands (can take up to 1 hour to appear).
GUILD_ID=your-server-id

# Comma-separated role IDs allowed to use the queue commands.
# Defaults to the two staff roles baked into the code if unset.
ALLOWED_ROLE_IDS=

# Optional. Force the bot to always use one queue channel.
QUEUE_CHANNEL_ID=

# Optional. Public image URL for the big banner at the top of the embed.
BANNER_IMAGE_URL=

# Optional.
QUEUE_BRAND_NAME=
QUEUE_THUMBNAIL_URL=
